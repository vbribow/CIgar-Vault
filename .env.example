FOUNDER_WRITE_KEY=
APP_ACCESS_USER=founder
APP_ACCESS_PASSWORD=
SITES_DEPLOYMENT=false

# Server-only OpenAI vision analysis. Never prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.6-terra
OPENAI_VALUATION_MODEL=gpt-5-mini
OPENAI_COMMUNITY_MODEL=gpt-5-mini
# Optional valuation safeguards. Defaults: 3 lots/run, $0.02 estimated/research, $10/month.
VALUATION_BATCH_SIZE=3
VALUATION_ESTIMATED_COST_USD=0.02
VALUATION_MONTHLY_BUDGET_USD=10

# Server-only Supabase administration for scheduled multi-user wishlist monitoring.
# Never expose this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# SensorPush Gateway Cloud API. Server-only; never prefix with NEXT_PUBLIC_.
SENSORPUSH_EMAIL=
SENSORPUSH_PASSWORD=

# Protects scheduled sensor synchronization and weekly catalog discovery.
CRON_SECRET=

# Optional climate alert delivery. Server-only.
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=

# Uses bundled seed data when true.
USE_MOCK_DATA=true
# Stripe Founder billing
STRIPE_SECRET_KEY=
STRIPE_FOUNDER_PRICE_ID=
