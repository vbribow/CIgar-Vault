# Server-only. Never expose this token with NEXT_PUBLIC_.
SMARTSHEET_ACCESS_TOKEN=
SMARTSHEET_WORKSPACE_ID=
SMARTSHEET_INVENTORY_SHEET_ID=
SMARTSHEET_CATALOG_SHEET_ID=
SMARTSHEET_SMOKING_LOG_SHEET_ID=
SMARTSHEET_VALUATIONS_SHEET_ID=
SMARTSHEET_ACTIVITY_SHEET_ID=
SMARTSHEET_COLLECTIONS_SHEET_ID=
SMARTSHEET_HUMIDORS_SHEET_ID=
SMARTSHEET_HUMIDOR_READINGS_SHEET_ID=
SMARTSHEET_SENSORS_SHEET_ID=
SMARTSHEET_ALERTS_SHEET_ID=
